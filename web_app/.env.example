# Скопируйте этот файл в .env и подправьте значения под вашу среду:
#   cp .env.example .env

# ── Куда монтировать каталог с jsonl-отчётами (хост-путь) ─────────────
# Можно абсолютный путь (рекомендуется на сервере):
#   TENDERS_DATA_DIR=/srv/tenders/jsonl
# Или относительный — относительно docker-compose.yml:
TENDERS_DATA_DIR=../storage/tenders/jsonl

# ── Порт на хосте, на котором будет доступно приложение ──────────────
# Используется в docker-compose.yml (без nginx):
HOST_PORT=5000
# Используется в docker-compose.nginx.yml:
HTTP_PORT=80

# ── Часовой пояс контейнера ──────────────────────────────────────────
TZ=Europe/Moscow
